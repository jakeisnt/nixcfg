#!/usr/bin/env nu

def "main commit" [] {
    $"*\n\n(main)\n\ntemperature:(main --simple)" | git commit -F -
}

def main [
    --location (-l): string # the location to search for
    --simple (-s) # just the temperature
] {
    let loc = if $location != null { $location } else { "" }

    if $simple {
        let url = if $loc != "" { $"wttr.in/($loc)?format=1" } else { "wttr.in/?format=1" }
        curl -s $url
    } else {
        let url = if $loc != "" { $"v3.wttr.in/($loc)" } else { "v3.wttr.in" }
        curl -s $url
    }
}
